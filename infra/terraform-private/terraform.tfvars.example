enable_private_data_plane = true
create_resource_group     = true
resource_group_name       = "rg-archiforge-private"
location                  = "eastus2"

# Full ARM resource IDs from Azure Portal or `az resource show`
sql_server_id       = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-data/providers/Microsoft.Sql/servers/archiforge-sql"
storage_account_id  = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-data/providers/Microsoft.Storage/storageAccounts/archiforgestg"

# Optional: Azure AI Search private endpoint + privatelink.search.windows.net zone (omit or "" to skip)
# search_service_id = "/subscriptions/.../providers/Microsoft.Search/searchServices/archiforge-search"

tags = {
  workload = "archiforge"
  layer    = "private-data"
}
