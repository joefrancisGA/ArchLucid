# Copy to terraform.tfvars (gitignored). Defaults keep everything off for safe validate in CI.
#
# Log Analytics workspace daily_quota_gb is not defined here — it lives in terraform-container-apps
# (variable log_analytics_daily_quota_gb). See production.tfvars.example in that stack.

enable_monitoring_stack = false
# resource_group_name     = "rg-archiforge-prod"
# name_prefix             = "archiforge"
# alert_email_address     = "ops@example.com"
# alert_webhook_uri       = "https://..." # optional Teams / PagerDuty

# Full resource IDs from Azure Portal or terraform-container-apps outputs (Container Apps).
# api_container_app_resource_id    = "/subscriptions/.../providers/Microsoft.App/containerApps/archiforge-api"
# worker_container_app_resource_id = "/subscriptions/.../providers/Microsoft.App/containerApps/archiforge-worker"

# ~0.5 vCPU sustained → 500000000 nano cores (tune per allocation).
# container_cpu_nanos_threshold = 500000000

# Optional: Azure Monitor managed Prometheus rule group (PromQL mirrors ../prometheus/archlucid-slo-rules.yml).
# enable_prometheus_slo_rule_group = true
# azure_monitor_workspace_id       = "/subscriptions/.../resourceGroups/.../providers/Microsoft.Monitor/accounts/..."

# Optional: Azure Managed Grafana (extra cost; assign Monitor Reader to the Grafana identity in Azure).
# enable_managed_grafana = true
# grafana_name           = "archiforge-grafana"
# grafana_location       = "eastus2"

# Optional: push ../grafana/*.json via Grafana Terraform provider (requires second apply + real token).
# grafana_terraform_dashboards_enabled = true
# grafana_url  = "https://your-workspace.grafana.azure.net"
# grafana_auth = "glsa_..."  # prefer TF_VAR_grafana_auth

tags = {
  workload = "archiforge"
  tier     = "monitoring"
}
