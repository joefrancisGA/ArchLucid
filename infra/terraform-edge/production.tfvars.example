# Production-oriented Front Door + WAF example. Merge into terraform.tfvars or:
#   terraform apply -var-file=production.tfvars.example
#
# Requires real origin hostnames (APIM, API, or UI) before apply.

enable_front_door_waf = true
create_resource_group = true
resource_group_name   = "rg-archlucid-edge-prod"
location              = "eastus2"

front_door_profile_name = "archlucid-prod-fd"

# Origin hostname without scheme (e.g. APIM default domain or your API public host).
backend_hostname = "your-apim-or-api-hostname.azure-api.net"

front_door_health_probe_path = "/health/ready"

# Microsoft_DefaultRuleSet (DRS): production uses 2.2 where supported — OWASP CRS-baselined managed
# rules per Azure WAF docs. If plan/apply rejects the version for your SKU, try "2.1" or check portal.
front_door_waf_default_rule_set_version = "2.2"

tags = {
  workload    = "archlucid"
  layer       = "edge-waf"
  environment = "production"
}
