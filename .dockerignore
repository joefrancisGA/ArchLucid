# ── Docker build context exclusions (repo root) ───────────────────
# Keeps the build context small and prevents secrets/build artifacts
# from leaking into the image.

# .NET build output
**/bin/
**/obj/
**/out/

# Test results / coverage
**/TestResults/
**/coverage*/

# IDE / editor
.vs/
.vscode/
.cursor/
**/*.user
**/*.suo

# Node (UI project — not needed for API image)
archlucid-ui/node_modules/
archlucid-ui/.next/
archlucid-ui/playwright-report/
archlucid-ui/test-results/

# Git
.git/
.gitignore

# Docker
**/Dockerfile*
docker-compose*.yml
**/.dockerignore

# Docs (not needed in images)
docs/

# CI
.github/

# Env / secrets
**/.env
**/.env.*
!**/.env.example
