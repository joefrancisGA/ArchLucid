# Backend API (used by Next.js server: RSC + /api/proxy)
ARCHIFORGE_API_BASE_URL=http://localhost:5128

# Optional: when ArchiForge API has Authentication:ApiKey:Enabled = true
ARCHIFORGE_API_KEY=

# Public base URL (optional; defaults below). Browser calls go through /api/proxy instead.
NEXT_PUBLIC_ARCHIFORGE_API_BASE_URL=http://localhost:5128

# UI auth seam: development-bypass | jwt | jwt-bearer
NEXT_PUBLIC_ARCHIFORGE_AUTH_MODE=development-bypass

# Optional: /api/proxy rate limit (in-process, per server instance). First X-Forwarded-For hop or X-Real-Ip.
# ARCHIFORGE_PROXY_RATE_LIMIT_PER_MINUTE=120
# ARCHIFORGE_PROXY_RATE_LIMIT_WINDOW_MS=60000
# ARCHIFORGE_PROXY_RATE_LIMIT_DISABLED=true
